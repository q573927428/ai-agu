# ====================================
# 后端环境变量配置 (复制此文件为 .env 并填入真实值)
# ====================================

# MySQL 数据库
MYSQL_ROOT_PASSWORD=你的_root密码
MYSQL_PASSWORD=你的_agu_user密码
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=agu_quant

# Backend
DATABASE_URL=mysql+pymysql://agu_user:你的_agu_user密码@localhost:3306/agu_quant
APP_ENV=development
LOG_LEVEL=INFO

# Model (可选)
MODEL_DIR=./models
MODEL_VERSION=v1.0

# Tushare (请在此填入你的 Tushare Pro token)
TUSHARE_TOKEN=你的_tushare_token

# AkShare 代理 (可选)
HTTP_PROXY=
HTTPS_PROXY=

# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:8000